# Kestra Hackathon Co-Pilot — environment variables
# Copy this file to .env and fill in real values.
# .env is gitignored.

# ─── LLM provider ──────────────────────────────────────────────
# Get from https://aistudio.google.com/apikey (free tier, generous quota)
GEMINI_API_KEY=

# ─── Code execution sandbox ────────────────────────────────────
# Sign up at https://rapidapi.com/judge0-official/api/judge0-ce/
RAPID_API_KEY=

# ─── GitHub (for the Communicator agent) ───────────────────────
# Fine-grained PAT with: repo write, contents write, metadata read
GITHUB_TOKEN=
GITHUB_USERNAME=

# ─── Slack (for the Communicator agent) ────────────────────────
# Incoming webhook URL — https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ─── Obsidian (persistent memory + graph) ──────────────────────
# ABSOLUTE host path to your Obsidian vault root.
# This gets mounted into the Kestra container as /obsidian.
# Examples:
#   macOS:   /Users/yourname/Documents/MyVault
#   Linux:   /home/yourname/Documents/MyVault
#   Windows: C:/Users/yourname/Documents/MyVault   (forward slashes!)
OBSIDIAN_VAULT_PATH=

# Folder inside the vault where notes are written.
# A fresh subfolder is recommended so the demo graph isn't polluted by your other notes.
OBSIDIAN_PROJECT_FOLDER=kestra-copilot

# Auto-commit Obsidian writes to git? (true/false)
# Requires the vault to already be a git repo with a configured remote.
OBSIDIAN_GIT_AUTOCOMMIT=true

# Optional: a SECOND git remote to also push to (the "Graphify" target).
# Leave blank to push only to the vault's default remote.
# Set to a remote name you've already added with `git remote add`.
GRAPHIFY_REMOTE=

# ─── Kestra ────────────────────────────────────────────────────
# Don't change unless you know why
KESTRA_NAMESPACE=hackathon.copilot
